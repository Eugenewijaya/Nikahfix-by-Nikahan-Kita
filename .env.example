# Production database for Vercel Functions + Neon Postgres backend.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Admin auth. Defaults in code are Owner / NikahanKitaEvid, but production should set these in Vercel.
ADMIN_USERNAME="Owner"
ADMIN_PASSWORD="change-this-before-production"
SESSION_SECRET="replace-with-a-long-random-secret"

# Public site URL used by generated links/messages.
VITE_PUBLIC_SITE_URL="https://your-domain.com"
