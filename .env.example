# Production database for the future Vercel Functions + Neon Postgres backend.
# Current template still stores CRUD data in browser localStorage.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Future admin auth/session secret for production hardening.
ADMIN_PASSWORD="change-this-before-production"
SESSION_SECRET="replace-with-a-long-random-secret"

# Public site URL used by backend jobs or generated messages after server migration.
VITE_PUBLIC_SITE_URL="https://your-domain.com"
